                    <div class="languages">
                        <h3>Languages</h3>
                        <div class="language-bars">
                            <div class="language-bar">
                                <span>English</span>
                                <div class="bar"><div class="progress" style="width: 90%"></div></div>
                            </div>
                            <div class="language-bar">
                                <span>Tamil</span>
                                <div class="bar"><div class="progress" style="width: 100%"></div></div>
                            </div>
                        </div>
                    </div>
