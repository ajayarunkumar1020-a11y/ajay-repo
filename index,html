                                <p>+91 XXXXX XXXXX</p>
                            </div>
                        </div>
                    </div>

                    <div class="strengths">
                        <h3>Strengths</h3>
                        <div class="strength-tags">
                            <span class="tag">Quick Learner</span>
                            <span class="tag">Problem Solving</span>
                            <span class="tag">Team Collaboration</span>
                            <span class="tag">Communication Skills</span>
