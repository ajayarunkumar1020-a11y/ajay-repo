                            <i class="fas fa-envelope"></i>
                            <div>
                                <h4>Email</h4>
                                <p>your.email@example.com</p>
                            </div>
                        </div>
                        <div class="info-card">
                            <i class="fas fa-phone"></i>
                            <div>
